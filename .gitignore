# Ignoriere ALLE Themes im Themes-Ordner
wp-content/themes/*

# Erlaube NUR das Enfold-Child Theme (WICHTIG: Das "!" hebt das Verbot auf)
!wp-content/themes/enfold-child/

# Sicherheit
wp-config.php

# Content & Medien

wp-content/uploads/*
!wp-content/uploads/document-uploader
!wp-content/uploads/response-uploader
wp-content/upgrade/
wp-content/backup-db/
wp-content/cache/

# Plugins (Normalerweise alle ignorieren)
wp-content/plugins/*
!wp-content/plugins/netzwerk-services
# Falls du bestimmte Plugins DOCH tracken willst, nutze: !wp-content/plugins/mein-plugin/

# Theme-spezifische Entwicklung (Enfold-Child)
wp-content/themes/enfold-child/node_modules/
wp-content/themes/enfold-child/vendor/
wp-content/themes/enfold-child/build/
wp-content/themes/enfold-child/.idea/

# Root-level Node Modules
node_modules/