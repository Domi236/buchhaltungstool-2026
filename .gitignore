# IDE & System
.idea/
.vscode/
*.log
.DS_Store
Thumbs.db

# WordPress Core (Sollte nicht in Git, da über Updates verwaltet)
wp-admin/
wp-includes/
index.php
license.txt
readme.html
wp-activate.php
wp-blog-header.php
wp-comments-post.php
